# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=ZUBACO Games
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_STAGE_NUMBER=1

# ── Game API ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://arrows.dev.ZUBACO.app
VITE_API_TIMEOUT=10000
VITE_DEV_SESSION_URL=https://ZUBACO-staging-mock-user.projectlabs.in/user/auth/dev-session

# ── Admin API (stage content / translations) ──────────────────────────────────
VITE_ADMIN_API_BASE_URL=
VITE_STAGE_ID=

# ── Encryption ────────────────────────────────────────────────────────────────
VITE_ENCRYPTION_KEY=
VITE_ENABLE_ENCRYPTION=false

# ── Feature flags ─────────────────────────────────────────────────────────────
VITE_FEATURE_DEVTOOLS=false
VITE_FEATURE_ANALYTICS=false

# ── Dev level bypass ──────────────────────────────────────────────────────────
# Set to true in .env.local to skip all API calls and load src/dev/devLevel.ts
VITE_DEV_LEVEL=false

# ── Analytics ─────────────────────────────────────────────────────────────────
VITE_ANALYTICS_ID=
