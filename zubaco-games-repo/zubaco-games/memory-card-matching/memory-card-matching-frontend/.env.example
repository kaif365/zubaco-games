# App
VITE_APP_NAME=ZUBACO Games
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API
VITE_API_BASE_URL=https://api.example.com/v1
VITE_API_TIMEOUT=10000
VITE_ADMIN_API_BASE_URL=https://ZUBACO-admin-backend.dev.ZUBACO.app
VITE_ASSET_BASE_URL=
VITE_MOCK_USER_URL=http://192.180.1.190:5002
VITE_STAGE_ID=d13e13c5-cd28-4ccf-82ea-c5b71a8edd11
# Optional: overrides API stage for theme / micro-screens (1–4). Same idea as sequence-recall.
VITE_STAGE_NUMBER=1

# Encryption (64-char hex key — leave empty to disable)
VITE_ENCRYPTION_KEY=

# Feature flags
VITE_FEATURE_DEVTOOLS=true
VITE_FEATURE_ANALYTICS=false

# Analytics (optional)
VITE_ANALYTICS_ID=

# Socket (optional — leave empty to disable WebSocket connection)
VITE_SOCKET_URL=
VITE_CLOUDFRONT_URL=https://your-domain.cloudfront.net
