# ─── ZUBACO Maze Game Service — Environment Configuration ────────────────────────────
NODE_ENV=development

# Database (PostgreSQL)
# Use sslmode=disable for local Postgres without SSL
DATABASE_URL="postgresql://user:password@localhost:5432/maze_db?schema=public&sslmode=disable"

# Server
PORT=3005

# Security
JWT_SECRET=REPLACE_WITH_REAL_SECRET_MIN_32_CHARS

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_MAZE_PROJECT_KEY="MAZE_SERVICE"
REDIS_ADMIN_PROJECT_KEY="ADMIN_SERVICE"
REDIS_USERS_PROJECT_KEY="USERS_SERVICE"

# Restate
RESTATE_INGRESS_URL=http://localhost:8080
RESTATE_ENDPOINT_PORT=9081

# Microservices
ADMIN_MICROSERVICE_BASE_URL="https://your-admin-backend-url/"
USERS_MICROSERVICE_BASE_URL="https://your-users-backend-url/"

# Swagger
PROJECT_NAME="Maze Game Service"
PROJECT_DESCRIPTION="ZUBACO Gaming Engine — Maze Game Microservice"
PROJECT_VERSION="1.0.0"

# Features
ADMIN_BYPASS=false
ENABLE_DEV_AUTH=false
ENABLE_SWAGGER=false

# Language
SUPPORTED_LANGUAGES=en
DEFAULT_LANGUAGE=en

# Throttle
THROTTLE_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_GAME_LIMIT=100
THROTTLE_DEFAULT_LIMIT=10

# Encryption (Required — must be a 64-char hex string / 32 bytes)
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# AWS SNS
AWS_SNS_CHEAT_TOPIC_ARN=arn:aws:sns:ap-south-1:your-account-id:your-topic-name

# AWS SQS
AWS_SQS_JOB_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account-id/your-queue-name
AWS_SQS_JOB_QUEUE_ARN=arn:aws:sqs:ap-south-1:your-account-id:your-queue-name

# Game
GAME_TYPE=3
