# ─── Infinity Loop Game Service — Environment Template ────────────────────────────
# Copy to .env.development or .env.production and fill in real values.
# Never commit files with real secrets.

NODE_ENV=development

# Database (PostgreSQL — Neon / RDS)
DATABASE_URL="postgresql://user:password@host/dbname"

# Server
PORT=3000

# Security
JWT_SECRET="change-me-min-32-chars"
ADMIN_BYPASS=false
ENABLE_DEV_AUTH=false
ENABLE_SWAGGER=false

# Redis
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_INFINITYLOOP_PROJECT_KEY=INFINITYLOOP_SERVICE
REDIS_ADMIN_PROJECT_KEY=ADMIN_SERVICE

# Swagger
PROJECT_NAME="Infinity Loop Game Service"
PROJECT_DESCRIPTION="Infinity Loop Gaming Engine — Infinity Loop Game Microservice"
PROJECT_VERSION="1.0.0"

# AWS (SNS anti-cheat)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_CHEAT_TOPIC_ARN=

# AWS SQS (job queue)
AWS_SQS_JOB_QUEUE_URL=
AWS_SQS_POLL_WAIT_SECONDS=20
AWS_SQS_MAX_MESSAGES=10

# Microservices
ADMIN_MICROSERVICE_BASE_URL=
USERS_MICROSERVICE_BASE_URL=

# Restate (game state)
RESTATE_INGRESS_URL=http://127.0.0.1:8080
RESTATE_ENDPOINT_PORT=9080

# Game Type (2 = Infinity Loop)
GAME_TYPE=2
GAME_TYPE_KEY=INFINITY_LOOP

# i18n
SUPPORTED_LANGUAGES=en
DEFAULT_LANGUAGE=en
