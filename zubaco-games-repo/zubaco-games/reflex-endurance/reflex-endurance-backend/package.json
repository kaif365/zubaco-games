{
  "name": "reflex-endurance-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "db:seed": "npx prisma db seed",
    "db:migrate": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset --force",
    "test:e2e": "jest --config jest-e2e.config.ts --forceExit --detectOpenHandles",
    "test": "jest --config jest.config.ts --forceExit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^7.8.0",
    "@restatedev/restate-sdk": "^1.14.4",
    "@restatedev/restate-sdk-clients": "^1.14.4",
    "bullmq": "^5.77.0",
    "compression": "^1.8.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "socket.io": "^4.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.23",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.4"
  },
  "prisma": {
    "seed": "npx ts-node --transpile-only prisma/seed.ts"
  }
}
