# App
VITE_APP_NAME=ZUBACO Games
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API
VITE_API_BASE_URL=https://api.example.com/v1
VITE_API_TIMEOUT=10000

# Feature flags
VITE_FEATURE_DEVTOOLS=true
VITE_FEATURE_ANALYTICS=false

# Analytics (optional)
VITE_ANALYTICS_ID=

# Socket (optional — leave empty to disable WebSocket connection)
VITE_SOCKET_URL=
VITE_STAGE_NO=1

# Admin API (stage content / translations)
VITE_ADMIN_API_BASE_URL=

# Encryption
VITE_ENCRYPTION_ENABLED=true
VITE_ENCRYPTION_KEY=<64-char-hex-string>
