# ─── Sliding Puzzle Game Service — Environment Template ────────────────────────────
# Copy to .env.development or .env.production and fill in real values.
# Never commit files with real secrets.

NODE_ENV=development
GAME_TYPE=2
GAME_TYPE_KEY=SLIDING_PUZZLE

# Database (PostgreSQL — Neon / RDS)
DATABASE_URL="postgresql://user:password@host/dbname"

# Server
PORT=3000

# Security
JWT_SECRET="change-me-min-32-chars"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SLIDING_PUZZLE_PROJECT_KEY=sliding-puzzle
REDIS_ADMIN_PROJECT_KEY=ZUBACO-admin
REDIS_USERS_PROJECT_KEY=ZUBACO-users

# Restate
RESTATE_INGRESS_URL=http://localhost:8080
RESTATE_ENDPOINT_PORT=9080

# AWS
AWS_REGION=ap-south-1
# Credentials are resolved by the AWS SDK default provider chain.
AWS_SNS_CHEAT_TOPIC_ARN=arn:aws:sns:ap-south-1:<account-id>:<topic-name>
AWS_SQS_JOB_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/<account-id>/<queue-name>
AWS_SQS_POLL_WAIT_SECONDS=20
AWS_SQS_MAX_MESSAGES=10
AWS_S3_BUCKET_NAME=<s3-bucket-name>
AWS_CLOUDFRONT_DOMAIN=<cloudfront-domain>

# Admin Microservice
ADMIN_MICROSERVICE_BASE_URL=http://localhost:4000

# Users Microservice
USERS_MICROSERVICE_BASE_URL=http://localhost:5000

# Swagger
PROJECT_NAME="Sliding Puzzle Game Service"
PROJECT_DESCRIPTION="ZUBACO Gaming Engine — Sliding Puzzle Game Microservice"
PROJECT_VERSION="1.0.0"

# i18n
SUPPORTED_LANGUAGES=en
DEFAULT_LANGUAGE=en

# Rate limiting
THROTTLE_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_GAME_LIMIT=100
THROTTLE_DEFAULT_LIMIT=10

# Encryption
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=<32-byte-hex-string>

# API Key (used for server-to-server endpoints, e.g. file upload)
API_KEY=<your-api-key>

# File upload
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
