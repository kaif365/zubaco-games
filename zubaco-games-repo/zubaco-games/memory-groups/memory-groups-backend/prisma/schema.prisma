generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}
datasource db {
  provider = "postgresql"
}
model Configuration {
  id                  String   @id @default(uuid())
  stageId             String   @unique
  showDurationMs      Int      @default(5000)
  timeLimitMs         Int      @default(60000)
  groupSize           Int      @default(3)
  totalGroups         Int      @default(3)
  pointsPerGroup      Int      @default(50)
  pointsPerPartialWord Int     @default(10)
  timeBonusMultiplier Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
model GameSession {
  id          String      @id @default(uuid())
  playerId    String
  stageId     String
  serverSeed  String
  clientSeed  String
  nonce       Int
  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  clientScore Int?
  serverScore Int?
  status      String      @default("active")
  cheatFlags  CheatFlag[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
model CheatFlag {
  id            String      @id @default(uuid())
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  gameSessionId String
  reason        String
  details       String?
  createdAt     DateTime    @default(now())
}
