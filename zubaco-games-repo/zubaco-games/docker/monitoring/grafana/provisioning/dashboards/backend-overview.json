{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "title": "Zubaco Games - Backend Overview",
  "uid": "zubaco-backend-overview",
  "tags": ["zubaco", "backend", "overview"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(process_uptime_seconds, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "count(up{job=\"zubaco-backends\"} == 1)" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 15}, {"color": "green", "value": 20}] } } }
    },
    {
      "title": "Total Requests/sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{instance=~\"$instance\"}[1m]))" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\",instance=~\"$instance\"}[5m])) / sum(rate(http_requests_total{instance=~\"$instance\"}[5m])) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}] } } }
    },
    {
      "title": "Active Game Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(game_sessions_active{instance=~\"$instance\"})" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "title": "p95 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])) by (le))" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}] } } }
    },
    {
      "title": "Cheat Flags /hr",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "sum(increase(game_cheat_flags_total{instance=~\"$instance\"}[1h]))" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 10}, {"color": "red", "value": 50}] } } }
    },
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total{instance=~\"$instance\"}[1m])) by (instance)", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status=~\"2..\",instance=~\"$instance\"}[1m]))", "legendFormat": "2xx Success" },
        { "expr": "sum(rate(http_requests_total{status=~\"4..\",instance=~\"$instance\"}[1m]))", "legendFormat": "4xx Client Error" },
        { "expr": "sum(rate(http_requests_total{status=~\"5..\",instance=~\"$instance\"}[1m]))", "legendFormat": "5xx Server Error" }
      ]
    },
    {
      "title": "Memory Usage by Service (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "process_resident_memory_bytes{instance=~\"$instance\"} / 1024 / 1024", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "title": "Game Sessions Started (per min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "sum(rate(game_sessions_started_total{instance=~\"$instance\"}[5m])) by (instance) * 60", "legendFormat": "{{instance}}" }]
    },
    {
      "title": "Game Sessions Completed by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "sum(rate(game_sessions_completed_total{status=\"completed\",instance=~\"$instance\"}[5m])) * 60", "legendFormat": "Completed" },
        { "expr": "sum(rate(game_sessions_completed_total{status=\"expired\",instance=~\"$instance\"}[5m])) * 60", "legendFormat": "Expired" },
        { "expr": "sum(rate(game_sessions_completed_total{status=\"cheated\",instance=~\"$instance\"}[5m])) * 60", "legendFormat": "Cheated" }
      ]
    },
    {
      "title": "Process Uptime (hours)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [{ "expr": "process_uptime_seconds{instance=~\"$instance\"} / 3600", "legendFormat": "{{instance}}", "format": "table", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "h" } }
    }
  ],
  "schemaVersion": 39,
  "version": 2
}
