{
  "name": "flash-spot-game-service",
  "version": "0.0.1",
  "description": "ZUBACO Gaming Engine � Flash Spot Game Microservice",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "bun --no-network-family-autoselection src/main.ts",
    "start:dev": "bun --no-network-family-autoselection --watch src/main.ts",
    "start:debug": "bun --no-network-family-autoselection --inspect --watch src/main.ts",
    "start:prod": "bun --no-network-family-autoselection src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "db:seed": "npx prisma db seed",
    "db:migrate": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset --force",
    "test:e2e": "jest --config jest-e2e.config.ts --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^7.3.0",
    "@restatedev/restate-sdk": "^1.14.4",
    "@restatedev/restate-sdk-clients": "^1.14.4",
    "bullmq": "^5.77.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.23",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4"
  },
  "prisma": {
    "seed": "npx ts-node --transpile-only prisma/seed.ts"
  }
}
