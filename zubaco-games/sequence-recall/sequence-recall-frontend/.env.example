# App
VITE_APP_NAME=ZUBACO Games
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API
VITE_API_BASE_URL=https://api.example.com/v1
VITE_API_TIMEOUT=10000

# Feature flags
VITE_FEATURE_DEVTOOLS=true
VITE_FEATURE_ANALYTICS=false

# Analytics (optional)
VITE_ANALYTICS_ID=
VITE_PARENT_ORIGIN=

# Socket (optional — leave empty to disable WebSocket connection)
VITE_SOCKET_URL=
VITE_STAGE_ID=5cdfb5fb-9db5-42ef-8f1e-64b42abf24d1

# Encryption (AES-256-GCM) — set ENABLED=true when the backend has encryption turned on
VITE_ENCRYPTION_ENABLED=false
VITE_PAYLOAD_AES_SECRET=
VITE_MOCK_USER_URL=https://ZUBACO-mock-user.onrender.com
VITE_ADMIN_API_BASE_URL=
