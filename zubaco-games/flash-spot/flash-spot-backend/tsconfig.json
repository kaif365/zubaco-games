{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@common/*": [
        "src/common/*"
      ],
      "@config": [
        "src/common/config/env.config"
      ],
      "@game/*": [
        "src/game/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}
