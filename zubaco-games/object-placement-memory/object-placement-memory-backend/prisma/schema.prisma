generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GameSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  stageId   String    @map("stage_id")
  status    Int       @default(1)

  serverSeed String?  @map("server_seed")
  seed       Int?     @map("seed")

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  score     Int?

  endTime          DateTime? @map("end_time")
  totalObjects     Int       @default(0) @map("total_objects")
  correctPlacements Int      @default(0) @map("correct_placements")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  inputs    GameInput[]
  flags     GameCheatFlag[]
  snapshot  GameSessionSnapshot?

  @@map("game_sessions")
  @@unique([userId, stageId])
  @@index([status])
  @@index([userId, status])
}

model GameSessionSnapshot {
  id                  String      @id @default(uuid())
  gameSessionId       String      @unique @map("game_session_id")
  session             GameSession @relation(fields: [gameSessionId], references: [id])

  gridSize            Int         @map("grid_size")
  objectCount         Int         @map("object_count")
  memorizeTimeMs      Int         @map("memorize_time_ms")
  recallTimeMs        Int         @map("recall_time_ms")
  pointsPerCorrect    Int         @map("points_per_correct")
  timeBonusMultiplier Float       @map("time_bonus_multiplier")

  createdAt           DateTime    @default(now()) @map("created_at")

  @@map("game_session_snapshots")
}

model GameInput {
  id            String      @id @default(uuid())
  gameSessionId String      @map("game_session_id")
  session       GameSession @relation(fields: [gameSessionId], references: [id])

  objectId      String      @map("object_id")
  placedCell    Int         @map("placed_cell")
  correctCell   Int         @map("correct_cell")
  isCorrect     Boolean     @default(false) @map("is_correct")
  clientTime    DateTime    @map("client_time")

  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("game_inputs")
  @@index([gameSessionId])
}

model GameConfiguration {
  id                  String   @id @default(uuid())
  stageId             String   @unique @map("stage_id")
  gridSize            Int      @default(4) @map("grid_size")
  objectCount         Int      @default(6) @map("object_count")
  memorizeTimeMs      Int      @default(5000) @map("memorize_time_ms")
  recallTimeMs        Int      @default(40000) @map("recall_time_ms")
  pointsPerCorrect    Int      @default(100) @map("points_per_correct")
  timeBonusMultiplier Float    @default(5) @map("time_bonus_multiplier")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("game_configurations")
}

model GameCheatFlag {
  id            String      @id @default(uuid())
  gameSessionId String      @map("game_session_id")
  session       GameSession @relation(fields: [gameSessionId], references: [id])
  userId        String      @map("user_id")
  flagType      Int         @map("flag_type")
  evidence      Json?       @map("evidence")

  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("game_cheat_flags")
  @@index([gameSessionId])
  @@index([userId, createdAt])
}
