generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Configuration {
  id               String   @id @default(uuid())
  stageId          String   @unique
  totalStatements  Int      @default(30)
  displayTimeMs    Int      @default(2000)
  timeLimitMs      Int      @default(60000)
  pointsPerCorrect Int      @default(10)
  penaltyPerWrong  Int      @default(5)
  streakThreshold  Int      @default(3)
  streakBonus      Int      @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GameSession {
  id          String      @id @default(uuid())
  
  playerId    String
  stageId     String
  
  serverSeed  String
  clientSeed  String
  nonce       Int
  
  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  
  clientScore Int?
  serverScore Int?
  status      String      @default("active")
  
  inputs      Input[]
  cheatFlags  CheatFlag[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Input {
  id              String      @id @default(uuid())
  gameSession     GameSession @relation(fields: [gameSessionId], references: [id])
  gameSessionId   String
  
  statementIndex  Int
  chosenTrue      Boolean
  correct         Boolean
  timestamp       BigInt
  
  createdAt       DateTime    @default(now())
}

model CheatFlag {
  id            String      @id @default(uuid())
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  gameSessionId String
  
  reason        String
  details       String?
  
  createdAt     DateTime    @default(now())
}
