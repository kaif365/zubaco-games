generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Configuration {
  id              String   @id @default(uuid())
  stageId         String   @unique
  nodeIntervalMs  Int      @default(2000)
  totalNodes      Int      @default(15)
  timeLimitMs     Int      @default(60000)
  canvasWidth     Int      @default(600)
  canvasHeight    Int      @default(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GameSession {
  id          String      @id @default(uuid())
  playerId    String
  stageId     String
  serverSeed  String
  clientSeed  String
  nonce       Int
  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  clientScore Int?
  serverScore Int?
  status      String      @default("active")
  edges       EdgeRecord[]
  cheatFlags  CheatFlag[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model EdgeRecord {
  id            String      @id @default(uuid())
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  gameSessionId String
  fromNode      Int
  toNode        Int
  timestamp     BigInt
  createdAt     DateTime    @default(now())
}

model CheatFlag {
  id            String      @id @default(uuid())
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  gameSessionId String
  reason        String
  details       String?
  createdAt     DateTime    @default(now())
}
