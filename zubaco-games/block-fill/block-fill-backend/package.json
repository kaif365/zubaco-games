{
  "name": "block-fill-game-service",
  "version": "0.0.1",
  "description": "ZUBACO Gaming Engine — Block Fill Microservice",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun --no-network-family-autoselection src/main.ts",
    "start:dev": "bun --no-network-family-autoselection --watch src/main.ts",
    "start:debug": "bun --no-network-family-autoselection --inspect --watch src/main.ts",
    "start:prod": "bun --no-network-family-autoselection src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config jest-e2e.config.ts --forceExit --detectOpenHandles",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "db:seed": "bun --no-network-family-autoselection prisma/seed.ts",
    "sonar": "bun --env-file=.env scripts/run-sonar.js"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.1041.0",
    "@aws-sdk/client-sqs": "^3.1041.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@restatedev/restate-sdk": "^1.14.0",
    "@restatedev/restate-sdk-clients": "^1.14.0",
    "@types/helmet": "^0.0.48",
    "axios": "^1.15.2",
    "bullmq": "^5.77.0",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "7.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "latest",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
