NODE_ENV=development
GAME_TYPE=2
GAME_TYPE_KEY=LOGIC_REFLECTOR
DATABASE_URL=postgresql://user:password@localhost:5432/logic_reflector_db
PORT=3001
JWT_SECRET=your-jwt-secret
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_REFLECTOR_PROJECT_KEY=logic-reflector
REDIS_ADMIN_PROJECT_KEY=admin
REDIS_USERS_PROJECT_KEY=users
RESTATE_INGRESS_URL=http://localhost:8080
RESTATE_ENDPOINT_PORT=9081
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_SNS_CHEAT_TOPIC_ARN=arn:aws:sns:us-east-1:123:cheat-topic
AWS_SQS_JOB_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123/job-queue
AWS_SQS_POLL_WAIT_SECONDS=20
AWS_SQS_MAX_MESSAGES=10
ADMIN_MICROSERVICE_BASE_URL=http://localhost:4000
USERS_MICROSERVICE_BASE_URL=http://localhost:4001
THROTTLE_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_GAME_LIMIT=100
THROTTLE_DEFAULT_LIMIT=10
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=your-32-byte-hex-key
LOGGING_COLOR_ENABLED=false
OTEL_SERVICE_NAME=logic-reflector-backend
