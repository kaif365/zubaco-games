# App
VITE_APP_NAME=ZUBACO Games
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# CDN — overlay / result images
VITE_CLOUDFRONT_URL=https://dy47qp4b6jtbv.cloudfront.net

# API
VITE_API_BASE_URL=https://api.example.com/v1
VITE_API_TIMEOUT=10000

# Stage — controls colour theme (1–7). Override at runtime with ?stage=N in URL.
VITE_STAGE_NO=1

# Feature flags
VITE_FEATURE_DEVTOOLS=true
VITE_FEATURE_ANALYTICS=false

# Analytics (optional)
VITE_ANALYTICS_ID=

# Socket (optional — leave empty to disable WebSocket connection)
VITE_SOCKET_URL=
