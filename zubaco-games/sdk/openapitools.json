{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.4.0",
    "generators": {
      "zubaco-sdk": {
        "generatorName": "typescript-axios",
        "output": "#{cwd}/generated/#{name}",
        "glob": "specs/*.json",
        "additionalProperties": {
          "supportsES6": true,
          "withInterfaces": true,
          "useSingleRequestParameter": true
        }
      }
    }
  }
}
