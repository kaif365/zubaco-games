# ╔══════════════════════════════════════════════════════════════╗
# ║  Backend Environment Template                               ║
# ╚══════════════════════════════════════════════════════════════╝
# Copy to .env and fill in values

# ─── Server ───
PORT=3006
NODE_ENV=development

# ─── Database (Prisma) ───
DATABASE_URL=postgresql://zubaco:zubaco_dev_2024@localhost:5432/colour_sorting

# ─── Security ───
# 64-char hex key for AES-256-GCM payload encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_SECRET=your-jwt-secret-min-32-chars-here

# ─── CORS ───
CORS_ORIGINS=http://localhost:3005

# ─── Rate Limiting ───
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Restate (optional – durable sessions) ───
# RESTATE_ENDPOINT_PORT=9080

# ─── AWS SNS (optional – event publishing) ───
# SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789:zubaco-events
# AWS_REGION=ap-south-1

# ─── Observability ───
# LOG_LEVEL=info
# METRICS_ENABLED=true
