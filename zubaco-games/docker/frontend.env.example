# Copy to .env and fill in values
# Vite exposes variables prefixed with VITE_ to client code

# ─── API Configuration ───
VITE_API_BASE_URL=http://localhost:3006/api/v1

# ─── Feature Flags ───
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DAILY_CHALLENGE=true
