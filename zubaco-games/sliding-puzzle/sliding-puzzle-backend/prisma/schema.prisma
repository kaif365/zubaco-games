generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Level ───────────────────────────────────────────────────────────────────

model Level {
  id        String    @id @default(uuid())

  name            String
  isDemo          Boolean   @default(false) @map("is_demo")
  difficultyScore Int       @default(0)     @map("difficulty_score")

  boards                Board[]
  stageLevelConfigs     StageLevelConfig[]
  stageDemoLevelConfigs StageDemoLevelConfig[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("levels")
  @@index([deletedAt])
}

// ─── Board ───────────────────────────────────────────────────────────────────

model Board {
  id        String    @id @default(uuid())

  levelId      String  @map("level_id")
  level        Level   @relation(fields: [levelId], references: [id])

  name         String
  gridX        Int     @map("grid_x")
  gridY        Int     @map("grid_y")
  fullImageUrl String  @map("full_image_url")

  sessionBoards GameSessionBoard[]
  demoBoards    UserStageDemoBoard[]
  shuffles      BoardShuffle[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("boards")
  @@index([levelId, deletedAt])
}

// ─── BoardShuffle ─────────────────────────────────────────────────────────────

model BoardShuffle {
  id      String @id @default(uuid())

  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id])

  pieces  Int[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("board_shuffles")
  @@index([boardId, deletedAt])
}

// ─── StageConfig ──────────────────────────────────────────────────────────────

model StageConfig {
  id        String    @id @default(uuid())

  stageId      String  @map("stage_id")
  timeLimit    Int     @map("time_limit")
  maxTimeBonus Int     @map("max_time_bonus")
  enableDemo   Boolean @default(false) @map("enable_demo")
  enableNumbers Boolean @default(true) @map("enable_numbers")
  isEnabled    Boolean @default(true)  @map("is_enabled")

  levels      StageLevelConfig[]
  demoLevels  StageDemoLevelConfig[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("stage_configs")
  @@index([deletedAt])
  @@index([stageId])
}

// ─── StageLevelConfig ─────────────────────────────────────────────────────────

model StageLevelConfig {
  id            String      @id @default(uuid())

  stageConfigId String      @map("stage_config_id")
  stageConfig   StageConfig @relation(fields: [stageConfigId], references: [id])

  levelId       String      @map("level_id")
  level         Level       @relation(fields: [levelId], references: [id])

  boardCount    Int         @map("board_count")
  displayTime   Int         @map("display_time")  // seconds to show full image before shuffling
  order         Int         @map("order")
  maxScore      Int         @map("max_score")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("stage_level_configs")
  @@index([levelId])
}

// ─── StageDemoLevelConfig ─────────────────────────────────────────────────────

model StageDemoLevelConfig {
  id            String      @id @default(uuid())

  stageConfigId String      @map("stage_config_id")
  stageConfig   StageConfig @relation(fields: [stageConfigId], references: [id])

  levelId       String      @map("level_id")
  level         Level       @relation(fields: [levelId], references: [id])

  boardCount    Int         @map("board_count")
  displayTime   Int         @map("display_time")  // seconds to show full image before shuffling
  order         Int         @map("order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("stage_demo_level_configs")
  @@index([levelId])
}

// ─── GameSession ─────────────────────────────────────────────────────────────

model GameSession {
  id        String    @id @default(uuid())

  userId    String    @map("user_id")
  stageId   String    @map("stage_id")
  expiryAt  DateTime  @map("expiry_at")

  status    Int       @default(1) @map("status")
  score     Int?
  timeBonus Int?      @map("time_bonus")

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime?                 @map("ended_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  stageConfigSnapshot GameSessionStageConfig?
  sessionBoards       GameSessionBoard[]
  moves               GameMove[]
  cheatFlags          CheatFlag[]

  @@map("game_sessions")
  @@index([userId])
  @@index([status])
  @@unique([userId, stageId])
  @@index([userId, stageId, status, deletedAt])
}

// ─── GameSessionStageConfig ───────────────────────────────────────────────────

model GameSessionStageConfig {
  id        String      @id @default(uuid())

  sessionId String      @unique @map("session_id")
  session   GameSession @relation(fields: [sessionId], references: [id])

  stageId      String  @map("stage_id")
  timeLimit    Int     @map("time_limit")
  maxTimeBonus Int     @map("max_time_bonus")
  enableNumbers Boolean @default(true) @map("enable_numbers")

  levelConfigs GameSessionStageLevelConfig[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("game_session_stage_configs")
}

// ─── GameSessionStageLevelConfig ──────────────────────────────────────────────

model GameSessionStageLevelConfig {
  id                   String                 @id @default(uuid())

  sessionStageConfigId String                 @map("session_stage_config_id")
  sessionStageConfig   GameSessionStageConfig @relation(fields: [sessionStageConfigId], references: [id])

  levelId     String @map("level_id")
  levelName   String @map("level_name")
  boardCount  Int    @map("board_count")
  displayTime Int    @map("display_time")
  order       Int    @map("order")
  maxScore    Int    @map("max_score")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("game_session_stage_level_configs")
  @@index([sessionStageConfigId])
}

// ─── GameSessionBoard ─────────────────────────────────────────────────────────

model GameSessionBoard {
  id          String      @id @default(uuid())

  sessionId   String      @map("session_id")
  session     GameSession @relation(fields: [sessionId], references: [id])

  roundNumber Int         @map("round_number")

  boardId      String  @map("board_id")
  board        Board   @relation(fields: [boardId], references: [id])
  levelId      String  @map("level_id")
  gridX        Int     @map("grid_x")
  gridY        Int     @map("grid_y")
  fullImageUrl String  @map("full_image_url")
  initialPieces Json   @map("initial_pieces")  // int[] snapshot of shuffle sent to FE

  score     Int?
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime?                 @map("ended_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  moves      GameMove[]
  cheatFlags CheatFlag[]

  @@map("game_session_boards")
  @@unique([sessionId, roundNumber])
  @@index([sessionId])
}

// ─── GameMove ─────────────────────────────────────────────────────────────────

model GameMove {
  id             String @id @default(uuid())

  sessionId      String      @map("session_id")
  session        GameSession @relation(fields: [sessionId], references: [id])

  sessionBoardId String           @map("session_board_id")
  sessionBoard   GameSessionBoard @relation(fields: [sessionBoardId], references: [id])

  clientMoveId String @map("client_move_id")

  fromSlot   Int     @map("from_slot")    // slot the piece slid from
  toSlot     Int     @map("to_slot")      // slot the piece slid into (where blank was)
  pieceIndex Int     @map("piece_index")  // which piece moved; -1 if invalid attempt
  success    Boolean

  clickedAt DateTime @map("clicked_at")

  @@unique([sessionId, clientMoveId])
  @@map("game_moves")
  @@index([sessionId, clickedAt])
}

// ─── CheatFlag ───────────────────────────────────────────────────────────────

model CheatFlag {
  id             String @id @default(uuid())

  userId         String           @map("user_id")
  sessionId      String           @map("session_id")
  session        GameSession      @relation(fields: [sessionId], references: [id])
  sessionBoardId String           @map("session_board_id")
  sessionBoard   GameSessionBoard @relation(fields: [sessionBoardId], references: [id])

  flagType Int  @map("flag_type")
  evidence Json

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("cheat_flags")
  @@index([userId])
  @@index([sessionId])
  @@index([sessionBoardId])
}

// ─── UserStageDemoBoard ───────────────────────────────────────────────────────

model UserStageDemoBoard {
  id      String @id @default(uuid())

  userId  String @map("user_id")
  stageId String @map("stage_id")
  levelId String @map("level_id")

  boardId      String @map("board_id")
  board        Board  @relation(fields: [boardId], references: [id])
  gridX        Int    @map("grid_x")
  gridY        Int    @map("grid_y")
  fullImageUrl String @map("full_image_url")
  initialPieces Json  @map("initial_pieces")
  displayTime  Int    @map("display_time")
  sortOrder    Int    @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_stage_demo_boards")
  @@index([userId, stageId])
}

// ─── File ─────────────────────────────────────────────────────────────────────
// Standalone upload registry. Not FK-referenced — consumers use key directly.

model File {
  id        String    @id @default(uuid())

  key       String    @unique
  fileName  String    @map("file_name")
  fileSize  Int       @map("file_size")
  mimeType  String    @map("mime_type")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  @@map("files")
  @@index([deletedAt])
}
