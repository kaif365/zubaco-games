NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memory_card_matching

PORT=3000
GAME_TYPE=6

PROJECT_NAME=Memory Card Matching Backend
PROJECT_DESCRIPTION=Memory Card Matching API
PROJECT_VERSION=1.0

THROTTLE_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_GAME_LIMIT=100
THROTTLE_DEFAULT_LIMIT=10

RESTATE_INGRESS_URL=http://localhost:8080
RESTATE_ENDPOINT_PORT=9080

ADMIN_MICROSERVICE_BASE_URL=http://localhost:4000
USERS_MICROSERVICE_BASE_URL=http://localhost:5000

GAME_STAGE_ID=default

AWS_REGION=ap-south-1
# Credentials are resolved by the AWS SDK default provider chain.
AWS_SNS_CHEAT_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:memory-card-cheat-topic
AWS_S3_BUCKET_NAME=memory-card-matching-local
AWS_CLOUDFRONT_DOMAIN=localhost

UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
