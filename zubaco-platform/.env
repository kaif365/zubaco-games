# ═══════════════════════════════════════════════════════════════
# Zubaco Platform - Local Development Environment
# ═══════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ────────────────────────────────────
# Option 1: Use free Neon.tech cloud postgres (sign up at https://neon.tech)
# Option 2: Use local Docker postgres (not available in this VM)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zubaco_platform?schema=public"
DATABASE_POOL_SIZE=5

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-secret-change-in-production-min-32-chars-long!!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-min32!!"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0

# ─── Razorpay (Test Mode) ────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
RAZORPAYX_ACCOUNT_NUMBER=your_razorpayx_account

# ─── Internal API ────────────────────────────────────────────
INTERNAL_API_KEY=dev-internal-api-key-change-in-production

# ─── Apple Sign In (optional for dev) ────────────────────────
APPLE_CLIENT_ID=com.zubaco.app
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_CORS_ORIGINS=http://localhost:3001
