{
  "name": "ZUBACO-games-admin-panel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "npm --prefix frontend exec -- eslint --fix --config frontend/eslint.config.mjs",
      "npm --prefix frontend exec -- prettier --write"
    ],
    "frontend/src/**/*.{css,md,json}": [
      "npm --prefix frontend exec -- prettier --write"
    ],
    "backend/src/**/*.ts": [
      "backend/node_modules/.bin/eslint --fix --config backend/eslint.config.mjs",
      "backend/node_modules/.bin/prettier --write"
    ]
  }
}
