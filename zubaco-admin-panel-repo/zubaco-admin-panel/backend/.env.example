# ZUBACO Admin Service - Environment Template
# Copy to .env.development or .env.production and fill in real values.
# Never commit files with real secrets.

NODE_ENV=development

# Database (PostgreSQL — Neon / RDS)
DATABASE_URL="postgresql://user:password@host/dbname"

# Server
PORT=3000

# Security
JWT_SECRET="change-me-min-32-chars"

# Seed Admin
ADMIN_SEED_EMAIL="admin@ZUBACO.com"
ADMIN_SEED_PASSWORD="Admin@123456"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ADMIN_PROJECT_KEY=ZUBACO-admin

# Swagger
PROJECT_NAME="ZUBACO Admin Service"
PROJECT_DESCRIPTION="ZUBACO Admin Service API"
PROJECT_VERSION="1.0.0"

# i18n
SUPPORTED_LANGUAGES=en
DEFAULT_LANGUAGE=en

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SQS — cheat-flag consumer (queue URL or SNS-wrapped queue URL)
AWS_SQS_CHEAT_FLAG_QUEUE_URL=

# SQS — per-game config event queues (SendMessage)
AWS_SQS_ARROWS_QUEUE_URL=
AWS_SQS_SEQUENCE_RECALL_QUEUE_URL=
AWS_SQS_BLOCK_FILL_QUEUE_URL=
AWS_SQS_INFINITY_LOOP_QUEUE_URL=
